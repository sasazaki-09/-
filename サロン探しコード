    '7. 毎回異なるサロンを選定すること。\n\n' +
    exclusionText +
    '【出力形式】\n以下のJSONのみ返してください。Markdownのコードブロックや説明文は絶対に含めないこと。\n' +
    '{\n  "salons": [\n    {\n      "salonName": "サロン名",\n      "area": "三宮・中央区 / 元町・神戸駅周辺 / 北野・山の手 / 須磨・垂水 / その他神戸 のどれか",\n      "url": "公式サイトURL（https://から始まる完全な形式。不明な場合は不明。架空URLは絶対に作らないこと）"\n    }\n  ]\n}\n\nsalonsは必ず5件返してください。';

  const payload = {
    contents: [{ parts: [{ text: prompt }] }],
    generationConfig: { temperature: 0.7, maxOutputTokens: 4000 }
  };

  const response = UrlFetchApp.fetch(GEMINI_ENDPOINT + '?key=' + GEMINI_API_KEY, {
    method: 'post', contentType: 'application/json',
    payload: JSON.stringify(payload), muteHttpExceptions: true
  });

  if (response.getResponseCode() !== 200) {
    throw new Error('Gemini APIエラー (HTTP ' + response.getResponseCode() + '): ' + response.getContentText().substring(0, 200));
