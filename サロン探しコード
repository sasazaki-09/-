  }
}

// ========================================================
// Gemini：サロン単体情報を取得（機能A用）
// ========================================================
function callGeminiForSalonInfo(salonName) {
  const prompt =
    '神戸の美容室・ヘアサロン「' + salonName + '」について以下のJSONのみ返してください。説明不要。\n' +
    '{\n' +
    '  "officialName": "正式名称",\n' +
    '"area": "三宮・中央区 / 元町・神戸駅周辺 / 北野・山の手 / 須磨・垂水 / その他神戸 のどれか",'
    '  "websiteUrl": "公式サイトURL（https://から始まる完全な形式。不明な場合は不明）"\n' +
    '}';

  const payload = {
    contents: [{ parts: [{ text: prompt }] }],
    generationConfig: { temperature: 0.1, maxOutputTokens: 256 }
  };

  const response = UrlFetchApp.fetch(GEMINI_ENDPOINT + '?key=' + GEMINI_API_KEY, {
    method: 'post', contentType: 'application/json',
    payload: JSON.stringify(payload), muteHttpExceptions: true
  });

  if (response.getResponseCode() !== 200) {
    throw new Error('Gemini APIエラー (HTTP ' + response.getResponseCode() + ')');
  }

  const responseJson = JSON.parse(response.getContentText());
  const rawText = responseJson.candidates[0].content.parts[0].text;
  const cleaned = rawText.replace(/```json\s*/gi, '').replace(/```\s*/g, '').trim();
  const match = cleaned.match(/\{[\s\S]*\}/);
  if (!match) throw new Error('JSONを抽出できませんでした。');

  const parsed = JSON.parse(match[0]);
  return {
    officialName: parsed.officialName || salonName,
    area:         parsed.area         || 'その他大阪',
    websiteUrl:   parsed.websiteUrl   || '不明'
  };
}

