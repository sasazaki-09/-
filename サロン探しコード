function fetchUrlBySerpApi_Salon(query) {
  try {
    const encodedQuery = encodeURIComponent(query);
    const serpUrl = 'https://serpapi.com/search.json?q=' + encodedQuery + '&hl=ja&gl=jp&api_key=' + SERP_API_KEY;

    const response = UrlFetchApp.fetch(serpUrl, { muteHttpExceptions: true });
    if (response.getResponseCode() !== 200) return '不明';

    const json    = JSON.parse(response.getContentText());
    const results = json.organic_results || [];

    const excludeDomains = [
      'wikipedia', 'twitter', 'instagram', 'facebook', 'linkedin',
      'youtube', 'amazon', 'rakuten', 'tabelog', 'hotpepper', 'indeed', 'wantedly'
    ];

    for (let i = 0; i < results.length; i++) {
      const link = results[i].link || '';
      const isExcluded = excludeDomains.some(function(d) { return link.includes(d); });
      if (!isExcluded && link.startsWith('http')) return link;
    }

    return '不明';
  } catch (e) {
    Logger.log('SerpApiエラー: ' + e.toString());
    return '不明';
  }
}

function filterEmailByGemini_Salon(salonName, candidates) {
  const filterPrompt =
    '以下のメールアドレス一覧の中から、美容室「' + salonName + '」への営業メール送信先として最も適切なものを1つ選んでください。\n' +
    '選定基準:\n- 優先: info@・contact@・pr@・hello@・salon@・beauty@\n- 除外: recruit@・career@・hr@・noreply@・no-reply@\n- ドメインがサロンの公式サイトと一致するものを優先\n\n' +
    '候補一覧:\n' + candidates.join('\n') + '\n\n以下のJSONのみ返してください。説明不要。\n{"email": "選んだメールアドレス"}';

  const payload = {
    contents: [{ parts: [{ text: filterPrompt }] }],
    generationConfig: { temperature: 0.1, maxOutputTokens: 128 }
  };

  try {
    Utilities.sleep(SLEEP_MEDIUM);
    const response = UrlFetchApp.fetch(GEMINI_ENDPOINT + '?key=' + GEMINI_API_KEY, {
      method: 'post', contentType: 'application/json',
      payload: JSON.stringify(payload), muteHttpExceptions: true
    });

    if (response.getResponseCode() !== 200) return candidates[0];

    const json    = JSON.parse(response.getContentText());
    const rawText = json.candidates[0].content.parts[0].text;
    const cleaned = rawText.replace(/```json\s*/gi, '').replace(/```\s*/g, '').trim();
    const match   = cleaned.match(/\{[\s\S]*\}/);

    if (match) {
      const parsed = JSON.parse(match[0]);
      if (parsed.email && parsed.email !== '×') return parsed.email;
    }
    return candidates[0];
  } catch (e) {
    Logger.log('フィルタリングエラー: ' + e.toString());
    return candidates[0];
  }
}

function isValidEmailCandidate_Salon(email) {
  const invalidPatterns = [
    '.png', '.jpg', '.jpeg', '.gif', '.svg', '.webp',
    '.css', '.js', '.woff', '.ttf',
    'example.com', 'schema.org', 'sentry', 'wixpress',
    'email@', '@example', '@domain', '@yourdomain',
    'noreply@', 'no-reply@', 'hotpepper.jp'
  ];
  return !invalidPatterns.some(function(p) { return email.toLowerCase().includes(p); });
}

// ========================================================
// ヘルパー：既存サロン名を取得
// ========================================================
function getExistingNames(sheet) {
  const lastRow = sheet.getLastRow();
  if (lastRow < START_ROW) return [];
  const numRows = lastRow - START_ROW + 1;
  const values  = sheet.getRange(START_ROW, COL_SALON, numRows, 1).getValues();
  return values
    .map(function(row) { return row[0].toString().trim(); })
    .filter(function(name) { return name !== ''; });
}

// ========================================================
// ヘルパー：次の書き込み行を取得
// ========================================================
function getNextWriteRow_Salon(sheet) { // ✅ リネーム
  const lastRow = sheet.getLastRow();
  if (lastRow < START_ROW) return START_ROW;
  return lastRow + 1;
}
