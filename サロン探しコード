// ========================================================
// 【機能B】5サロンサーチ＆アタックリスト自動記入
// ========================================================
function searchFiveSalons() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const inputSheet = ss.getSheets()[0];

  inputSheet.getRange('A5').setValue('🔍 5サロンサーチ中...');
  SpreadsheetApp.flush();

  try {
    const attackSheet = ss.getSheetByName(ATTACK_SHEET_NAME);
    if (!attackSheet) {
      inputSheet.getRange('A5').setValue('❌ 「' + ATTACK_SHEET_NAME + '」シートが見つかりません');
      return;
    }

    const existingNames = getExistingNames(attackSheet);
    const salons = searchFiveSalonsByGemini(existingNames);

    if (!salons || salons.length === 0) {
      inputSheet.getRange('A5').setValue('❌ サロンが取得できませんでした');
      return;
    }

    const lastRow = attackSheet.getLastRow();
    let writeRow = lastRow < START_ROW ? START_ROW : lastRow + 1;

    let addedCount = 0;
    for (let i = 0; i < salons.length; i++) {
      const salon = salons[i];

      if (existingNames.indexOf(salon.salonName) !== -1) {
        Logger.log('重複スキップ: ' + salon.salonName);
        continue;
      }

      attackSheet.getRange(writeRow + addedCount, COL_SALON).setValue(salon.salonName);
      attackSheet.getRange(writeRow + addedCount, COL_AREA).setValue(salon.area);

      let officialUrl = salon.url;
      if (!officialUrl || officialUrl === '不明' || !officialUrl.startsWith('http')) {
        officialUrl = fetchUrlBySerpApi_Salon(salon.salonName + ' 美容室 大阪');
      } else {
        try {
          const checkRes = UrlFetchApp.fetch(officialUrl, { muteHttpExceptions: true, followRedirects: true });
          if (checkRes.getResponseCode() !== 200) {
            officialUrl = fetchUrlBySerpApi_Salon(salon.salonName + ' 美容室 大阪');
          }
        } catch (e) {
          officialUrl = fetchUrlBySerpApi_Salon(salon.salonName + ' 美容室 大阪');
        }
      }
      attackSheet.getRange(writeRow + addedCount, COL_URL).setValue(officialUrl);

      addedCount++;
      Utilities.sleep(SLEEP_LONG);
    }

    const skippedCount = salons.length - addedCount;
    const resultMsg = addedCount > 0
      ? 'アタックリストの' + writeRow + '行目から' + addedCount + 'サロンを追記しました。'
        + (skippedCount > 0 ? '\n（重複 ' + skippedCount + '件はスキップ）' : '')
      : '追記できる新規サロンがありませんでした。\n（全' + skippedCount + '件が重複）';

    inputSheet.getRange('A5').setValue('✅ 完了！' + resultMsg);
    SpreadsheetApp.getUi().alert('✅ 5サロンサーチ完了！\n\n' + resultMsg + '\n\n次に「メールサーチ実行」ボタンを押してください。');

  } catch (e) {
    inputSheet.getRange('A5').setValue('❌ エラー: ' + e.message);
    Logger.log('エラー詳細: ' + e.toString());
    SpreadsheetApp.getUi().alert('エラーが発生しました:\n' + e.message);
  }
}

