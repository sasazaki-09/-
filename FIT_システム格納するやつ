# ============================================================

print("\n" + "=" * 60)
print("  Google Drive フォルダ作成・画像格納開始")
print("=" * 60)

# ── ルートフォルダ「2026AW_FIT」を作成 ───────────────────
root_folder_name = "2026AW_FIT"
root_folder_id = get_or_create_folder(drive_service, root_folder_name)
print(f"\n📁 ルートフォルダ「{root_folder_name}」: {root_folder_id}")

# ── モデルごとに処理 ─────────────────────────────────────
for col in all_cols:
    model_name = str(cell_values.get((ROW_MODEL_NAME, col), f'col{col}')).strip()
    # フォルダ名に使えない文字を除去
    order = all_cols.index(col) + 1  # 出演順（1始まり）
    safe_name = re.sub(r'[\\/:*?"<>|]', '_', f"{order:02d}_{model_name}")
    col_idx_0 = col - 1  # 0始まりのインデックス（Sheets API用）

    print(f"\n{'─'*50}")
    print(f"  📂 {model_name} （列{col}）")

    # モデル別フォルダを作成
    model_folder_id = get_or_create_folder(drive_service, safe_name, root_folder_id)

    # ── 画像取得ヘルパー ──────────────────────────────────
    def get_img(row):
        """指定行・現在の列から埋め込み画像を取得"""
        if row is None:
            return None
        return embedded_imgs.get((row, col))

    def get_text(row):
        """指定行・現在の列からテキストを取得"""
        if row is None:
            return ''
        val = cell_values.get((row, col), '')
        return str(val).strip() if val else ''

    # ── ① クローズ（全身）画像 ─────────────────────────
    close_img = get_img(ROW_CLOSE)
    if close_img:
        upload_image_to_drive(drive_service, close_img, '①クローズ（全身）.png', model_folder_id)
        print(f"    ✅ ①クローズ（全身）")
    else:
        upload_placeholder(drive_service, '①クローズ（全身）', model_folder_id)
        print(f"    ❌ ①クローズ（全身）: 画像なし")

    # ── ② 下駄画像（Sheets API優先、なければExcel埋め込み）─
    geta_img = geta_images_by_col.get(col_idx_0) or get_img(ROW_GETA)
    if geta_img:
        upload_image_to_drive(drive_service, geta_img, '②下駄.png', model_folder_id)
        print(f"    ✅ ②下駄")
    else:
        upload_placeholder(drive_service, '②下駄', model_folder_id)
        print(f"    ❌ ②下駄: 画像なし")

    # ── ③ コサージュ画像 ───────────────────────────────
    corsage_img = get_img(ROW_CORSAGE)
    if corsage_img:
        upload_image_to_drive(drive_service, corsage_img, '③コサージュ.png', model_folder_id)
        print(f"    ✅ ③コサージュ")
    else:
        upload_placeholder(drive_service, '③コサージュ', model_folder_id)
        print(f"    ❌ ③コサージュ: 画像なし")

    # ── ④ ※制作: ピアス＋他小物 PPTX ─────────────────
    pierce_img   = get_img(ROW_PIERCE)
    kokomono_img = get_img(ROW_KOKOMONO)

    if pierce_img and kokomono_img:
        try:
            kokomono_img_out = create_pierce_kokomono_image(PPTX_KOKOMONO, pierce_img, kokomono_img)
            upload_image_to_drive(drive_service, kokomono_img_out, '④ピアス＋他小物（制作）.png', model_folder_id)
            print(f"    ✅ ④ピアス＋他小物（制作PNG）")
        except Exception as e:
            print(f"    ❌ ④ピアス＋他小物: {e}")

    elif pierce_img and not kokomono_img:
        upload_image_to_drive(drive_service, pierce_img, '④ピアスのみ.png', model_folder_id)
        print(f"    ✅ ④ピアスのみ（他小物なし）")

    elif kokomono_img and not pierce_img:
        upload_image_to_drive(drive_service, kokomono_img, '④他小物のみ.png', model_folder_id)
        print(f"    ✅ ④他小物のみ（ピアスなし）")

    else:
        upload_placeholder(drive_service, '④ピアス＋他小物', model_folder_id)
        print(f"    ❌ ④ピアス＋他小物: 画像なし")

    # ── ⑤ ※制作: メイク＋ヘア PPTX ───────────────────
    hair_img     = get_img(ROW_HAIR)
    hair_text    = get_text(ROW_HAIR_TEXT)
    makeup1_img  = get_img(ROW_MAKEUP1)
    makeup1_text = get_text(ROW_MAKEUP1_TXT)
    makeup2_img  = get_img(ROW_MAKEUP2)
    makeup2_text = get_text(ROW_MAKEUP2_TXT)

    # 「本人に任せます」の場合、代替画像を単体でアップロード
    for label, img, text in [
        ('⑤ヘア',    hair_img,    hair_text),
        ('⑤メイク1', makeup1_img, makeup1_text),
        ('⑤メイク2', makeup2_img, makeup2_text),
    ]:
        if text == '本人に任せます' and not img and ALT_IMAGE is not None:
            upload_image_to_drive(drive_service, ALT_IMAGE, '本人に任せる.png', model_folder_id)
            print(f"    ✅ {label}: 本人に任せる.png を格納")
            break  # 3行共通1枚なので1回のみアップロード

    # テキストが全て「本人に任せます」かつ画像なしの場合はPNG生成しない
    all_honin = all(
        (t == '本人に任せます' and not i)
        for i, t in [(hair_img, hair_text), (makeup1_img, makeup1_text), (makeup2_img, makeup2_text)]
    )
    has_makeup_content = any([hair_img, makeup1_img, makeup2_img,
                               hair_text, makeup1_text, makeup2_text]) and not all_honin
    if has_makeup_content:
        try:
            makeup_img_out = create_makeup_image(
                PPTX_MAKEUP,
                hair_img, hair_text,
                makeup1_img, makeup1_text,
                makeup2_img, makeup2_text
            )
            upload_image_to_drive(drive_service, makeup_img_out, '⑤メイク＋ヘア（制作）.png', model_folder_id)
            print(f"    ✅ ⑤メイク＋ヘア（制作PNG）")
            print(f"       ヘア: {'画像✅' if hair_img else '画像❌'} / テキスト: {hair_text[:20] if hair_text else 'なし'}")
            print(f"       メイク1: {'画像✅' if makeup1_img else '画像❌'} / テキスト: {makeup1_text[:20] if makeup1_text else 'なし'}")
            print(f"       メイク2: {'画像✅' if makeup2_img else '画像❌'} / テキスト: {makeup2_text[:20] if makeup2_text else 'なし'}")
        except Exception as e:
            print(f"    ❌ ⑤メイク＋ヘア: {e}")
    else:
        print(f"    ❌ ⑤メイク＋ヘア: 画像・テキストなし")
      

