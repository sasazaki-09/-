def get_or_create_folder(drive_service, name, parent_id=None):
    """フォルダが存在すればIDを返し、なければ作成してIDを返す"""
    query = f"name='{name}' and mimeType='application/vnd.google-apps.folder' and trashed=false"
    if parent_id:
        query += f" and '{parent_id}' in parents"
    results = drive_service.files().list(q=query, fields='files(id, name)').execute()
    files_list = results.get('files', [])
    if files_list:
        return files_list[0]['id']
    metadata = {'name': name, 'mimeType': 'application/vnd.google-apps.folder'}
    if parent_id:
        metadata['parents'] = [parent_id]
    folder = drive_service.files().create(body=metadata, fields='id').execute()
    return folder['id']


def upload_image_to_drive(drive_service, pil_image, filename, folder_id):
    """PILImageをGoogle DriveのフォルダにPNGとしてアップロード"""
    buf = BytesIO()
    pil_image.save(buf, format='PNG')
    buf.seek(0)
    metadata = {'name': filename, 'parents': [folder_id]}
    media = MediaIoBaseUpload(buf, mimetype='image/png')
    drive_service.files().create(body=metadata, media_body=media, fields='id').execute()


def upload_pptx_to_drive(drive_service, pptx_path, filename, folder_id):
    """PPTXファイルをGoogle DriveのフォルダにアップロードPPTXとして"""
    with open(pptx_path, 'rb') as f:
        buf = BytesIO(f.read())
    buf.seek(0)
    metadata = {'name': filename, 'parents': [folder_id]}
    media = MediaIoBaseUpload(buf, mimetype='application/vnd.openxmlformats-officedocument.presentationml.presentation')
    drive_service.files().create(body=metadata, media_body=media, fields='id').execute()


# ──────────────────────────────────────────────
# PPTXテンプレート操作
# ──────────────────────────────────────────────
def replace_picture_in_shape(shape, pil_image):
    """shapeの画像をpil_imageで置き換える"""
    buf = BytesIO()
    pil_image.save(buf, format='PNG')
    buf.seek(0)
    blip = shape._element.find('.//{http://schemas.openxmlformats.org/drawingml/2006/main}blip')
    if blip is None:
        return False
    r_embed = '{http://schemas.openxmlformats.org/officeDocument/2006/relationships}embed'
    _, new_rId = shape.part.get_or_add_image_part(buf)
    blip.set(r_embed, new_rId)
    return True


def set_textbox_text(shape, text):
    """テキストボックスのテキストを設定（既存の書式を保持）"""
    tf = shape.text_frame
    if tf.paragraphs and tf.paragraphs[0].runs:
        tf.paragraphs[0].runs[0].text = str(text)
    else:
        tf.paragraphs[0].text = str(text)


def add_image_to_slide(slide, pil_image, left, top, width, height):
    """スライドに画像を指定位置・サイズで追加"""
    buf = BytesIO()
    pil_image.save(buf, format='PNG')
    buf.seek(0)
    slide.shapes.add_picture(buf, left, top, width, height)


def add_textbox_to_slide(slide, text, left, top, width, height,
                          font_size=None, underline=False, bold=False):
    """スライドにテキストボックスを追加"""
    from pptx.util import Pt
    txBox = slide.shapes.add_textbox(left, top, width, height)
    tf = txBox.text_frame
    tf.word_wrap = True
    para = tf.paragraphs[0]
    run = para.add_run()
    run.text = str(text)
    if font_size:
        run.font.size = Pt(font_size)
    run.font.underline = underline
    run.font.bold = bold
    return txBox


