ROW_MAKEUP1     = makeup_rows[0] if len(makeup_rows) >= 1 else None  # A66
ROW_MAKEUP2     = makeup_rows[1] if len(makeup_rows) >= 2 else None  # A68

# テキスト行（画像行の直後）
ROW_HAIR_TEXT   = ROW_HAIR + 1   if ROW_HAIR   else None  # A62: ヘアテキスト
ROW_MAKEUP1_TXT = ROW_MAKEUP1 + 1 if ROW_MAKEUP1 else None  # A67
ROW_MAKEUP2_TXT = ROW_MAKEUP2 + 1 if ROW_MAKEUP2 else None  # A69

# コサージュ・ピアス・他小物は見出し行（見出し自体に画像なし）
# → 次行（品番行）は参照しない。見出し行自体に画像が埋め込まれている
ROW_KOKOMONO    = find_row_by_label(ws, '他小物')         # A63: 他小物（見出し行）

print(f"  モデル名:    行{ROW_MODEL_NAME}")
print(f"  クローズ:    行{ROW_CLOSE}")
print(f"  下駄:        行{ROW_GETA}  ※Sheets APIで取得")
print(f"  コサージュ1: 行{ROW_CORSAGE}")
print(f"  ピアス:      行{ROW_PIERCE}")
print(f"  他小物:      行{ROW_KOKOMONO}")
print(f"  ヘア(画像):  行{ROW_HAIR}")
print(f"  ヘア(テキスト): 行{ROW_HAIR_TEXT}")
print(f"  メイク1(画像): 行{ROW_MAKEUP1} / テキスト: 行{ROW_MAKEUP1_TXT}")
print(f"  メイク2(画像): 行{ROW_MAKEUP2} / テキスト: 行{ROW_MAKEUP2_TXT}")

if not all([ROW_MODEL_NAME, ROW_CLOSE, ROW_GETA, ROW_CORSAGE,
            ROW_PIERCE, ROW_KOKOMONO, ROW_HAIR, ROW_MAKEUP1, ROW_MAKEUP2]):
    print("  ⚠ 取得できなかった行があります。A列のラベルを確認してください。")

# ── 下駄画像をSheets APIで取得（Excel変換で消える対策） ────
geta_images_by_col = {}  # {col_index(0始まり): PILImage}
if SPREADSHEET_ID and GID and ROW_GETA:
    print(f"\n🔍 下駄画像をSheets APIで取得中（行{ROW_GETA}）...")
    creds.refresh(auth_req)
    geta_urls = get_cell_images_from_sheets_api(
        sheets_service, SPREADSHEET_ID, GID,
        target_row_index=ROW_GETA - 1  # 0始まりに変換
    )
    for col_idx, url in geta_urls.items():
        img = download_image_from_url(url, creds)
        if img:
            geta_images_by_col[col_idx] = img
            print(f"  ✅ 列{col_idx+1}: 下駄画像取得")
        else:
            print(f"  ❌ 列{col_idx+1}: 下駄画像取得失敗")
    print(f"  取得完了: {len(geta_images_by_col)}件")
else:
    print("\n  ⚠ Sheets API未使用（URLモード以外）: 下駄画像はExcel埋め込みを使用")

# ── モデル列の特定 ────────────────────────────────────────
all_cols = []
for col in range(2, 60):
    name_val = cell_values.get((ROW_MODEL_NAME, col))
    if name_val and str(name_val).strip() not in ['', ' - ', '-']:
        all_cols.append(col)
print(f"\n👥 モデル数: {len(all_cols)}名")
for col in all_cols:
    name = cell_values.get((ROW_MODEL_NAME, col), '')
    print(f"  列{col}: {name}")
