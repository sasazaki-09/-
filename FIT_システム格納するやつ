# ※制作スライド生成: 他小物（ピアス＋他小物）
# ──────────────────────────────────────────────
def create_pierce_kokomono_image(template_path, pierce_img, kokomono_img):
    """
    PPTXテンプレートのスライドサイズ・画像スロット位置を読み取り
    同じレイアウトでPNG画像として合成して返す
    """
    from PIL import ImageDraw
    import pptx.util as putil

    prs = Presentation(template_path)
    slide = prs.slides[0]

    # スライド全体サイズ（EMU→px 96dpi換算）
    EMU_PER_PX = 914400 / 96
    W = int(prs.slide_width / EMU_PER_PX)
    H = int(prs.slide_height / EMU_PER_PX)

    canvas = PILImage.new('RGB', (W, H), 'white')

    # 画像スロットをleft順（左=ピアス、右=他小物）で取得
    pic_shapes = sorted(
        [s for s in slide.shapes if s.shape_type == 13],
        key=lambda s: s.left
    )

    # キャンバスを左右2分割して各画像をフィットさせる
    margin = int(W * 0.04)  # 4%余白
    slot_w = (W - margin * 3) // 2
    slot_h = int(H * 0.75)
    top_y = (H - slot_h) // 2

    imgs = [pierce_img, kokomono_img]
    for i, img in enumerate(imgs):
        if img is None:
            continue
        x = margin + i * (slot_w + margin)
        pil_img = img.copy().convert('RGB')
        pil_img.thumbnail((slot_w, slot_h), PILImage.LANCZOS)
        paste_x = x + (slot_w - pil_img.width) // 2
        paste_y = top_y + (slot_h - pil_img.height) // 2
        canvas.paste(pil_img, (paste_x, paste_y))

    return canvas


# ──────────────────────────────────────────────
# ※制作スライド生成: メイク（ヘア＋メイク×2）
# ──────────────────────────────────────────────
def find_row_exclude(ws, label, exclude):
    norm_label = normalize(label)
    norm_exclude = normalize(exclude)
    for row in ws.iter_rows(min_col=1, max_col=1):
        for cell in row:
            if cell.value:
                norm_val = normalize(str(cell.value))
                if norm_label in norm_val and norm_exclude not in norm_val:
                    return cell.row
    return None


def upload_placeholder(drive_service, label, folder_id):
    """画像なしの場合にテキストファイルをアップロード"""
    buf = io.BytesIO(f"{label}画像なし".encode('utf-8'))
    metadata = {'name': f'{label}画像なし.txt', 'parents': [folder_id]}
    media = MediaIoBaseUpload(buf, mimetype='text/plain')
    drive_service.files().create(body=metadata, media_body=media, fields='id').execute()

# ──────────────────────────────────────────────
# ⑤制作画像生成: メイク＋ヘア（PNG合成）
# ──────────────────────────────────────────────
def create_makeup_image(template_path, hair_img, hair_text,
                        makeup1_img, makeup1_text,
                        makeup2_img, makeup2_text):
    """
    PPTXテンプレートのスライドサイズ・画像/テキストスロット位置を読み取り
    同じレイアウトでPNG画像として合成して返す
    """
    from PIL import ImageDraw, ImageFont

    prs = Presentation(template_path)
    slide = prs.slides[0]

    EMU_PER_PX = 914400 / 96
    W = int(prs.slide_width / EMU_PER_PX)
    H = int(prs.slide_height / EMU_PER_PX)

    canvas = PILImage.new('RGB', (W, H), 'white')
    draw = ImageDraw.Draw(canvas)

    # Colab日本語フォントインストール（未インストール時のみ）
    import subprocess
    subprocess.run(['apt-get', 'install', '-y', '-q', 'fonts-noto-cjk'], capture_output=True)
    from PIL import ImageFont
    import glob
    noto_paths = glob.glob('/usr/share/fonts/**/NotoSansCJK*.ttc', recursive=True) + \
                 glob.glob('/usr/share/fonts/**/NotoSansCJK*.otf', recursive=True)
    FONT_PATH = noto_paths[0] if noto_paths else None

    def get_font(size_pt):
        px = max(int(size_pt * 96 / 72), 10)
        if FONT_PATH:
            try:
                return ImageFont.truetype(FONT_PATH, px)
            except:
                pass
        return ImageFont.load_default()

    # 画像スロット: top順（ヘア=最上段、以降メイク左右）
    pic_shapes = sorted(
        [s for s in slide.shapes if s.shape_type == 13],
        key=lambda s: s.top
    )
    makeup_pics = sorted(pic_shapes[1:], key=lambda s: s.left)

    img_slots = [
        (pic_shapes[0] if len(pic_shapes) >= 1 else None, hair_img),
        (makeup_pics[0] if len(makeup_pics) >= 1 else None, makeup1_img),
        (makeup_pics[1] if len(makeup_pics) >= 2 else None, makeup2_img),
    ]
    for shape, img in img_slots:
        if shape is None or img is None:
            continue
        x = int(shape.left / EMU_PER_PX)
        y = int(shape.top / EMU_PER_PX)
        w = int(shape.width / EMU_PER_PX)
        h = int(shape.height / EMU_PER_PX)
        pil_img = img.copy().convert('RGB')
        pil_img = pil_img.resize((w, h), PILImage.LANCZOS)
        canvas.paste(pil_img, (x, y))

    # テキストスロット: width最大=ヘア、残りleft順=メイク左右
    txt_shapes = [s for s in slide.shapes if s.shape_type == 17]
    txt_by_width = sorted(txt_shapes, key=lambda s: s.width, reverse=True)
    makeup_txts = sorted(
        [s for s in txt_shapes if s != txt_by_width[0]],
        key=lambda s: s.left
    )

    txt_slots = [
        (txt_by_width[0] if txt_by_width else None, hair_text),
        (makeup_txts[0] if len(makeup_txts) >= 1 else None, makeup1_text),
        (makeup_txts[1] if len(makeup_txts) >= 2 else None, makeup2_text),
    ]

    # フォントサイズ：ヘア=20px、メイク=18px（テンプレ実測から設定）
    font_hair  = get_font(30)   # ヘアテキスト用
    font_makeup = get_font(30)  # メイクテキスト用

    for i, (shape, text) in enumerate(txt_slots):
        if shape is None or not text:
            continue
        x = int(shape.left / EMU_PER_PX)
        y = int(shape.top / EMU_PER_PX)
        w = int(shape.width / EMU_PER_PX)
        font = font_hair if i == 0 else font_makeup
        text_str = str(text).replace('\r\n', '\n').replace('\r', '\n')

        # テキストをスロット幅内で中央揃え
        bbox = draw.textbbox((0, 0), text_str, font=font)
        text_w = bbox[2] - bbox[0]
        centered_x = x + (w - text_w) // 2
        draw.text((centered_x, y), text_str, font=font, fill='black')
    return canvas
