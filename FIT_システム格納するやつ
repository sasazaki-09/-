# ──────────────────────────────────────────────
# URLからSpreadsheet IDとGIDを抽出
# ──────────────────────────────────────────────
def extract_ids_from_url(url):
    spreadsheet_id = re.search(r'/spreadsheets/d/([a-zA-Z0-9-_]+)', url)
    gid = re.search(r'gid=(\d+)', url)
    return (
        spreadsheet_id.group(1) if spreadsheet_id else None,
        gid.group(1) if gid else None,
    )


# ──────────────────────────────────────────────
# A列ラベルから行番号を取得（部分一致・改行無視）
# ──────────────────────────────────────────────
def normalize(s):
    """改行・空白・全角スペースを除去して比較用に正規化"""
    return re.sub(r'[\s\u3000]+', '', str(s))

def find_row_by_label(ws, label):
    """A列を走査してlabelを含む最初の行番号を返す（None=未発見）"""
    norm_label = normalize(label)
    for row in ws.iter_rows(min_col=1, max_col=1):
        for cell in row:
            if cell.value and norm_label in normalize(str(cell.value)):
                return cell.row
    return None

def find_rows_by_label(ws, label):
    """A列を走査してlabelを含む全行番号をリストで返す"""
    norm_label = normalize(label)
    result = []
    for row in ws.iter_rows(min_col=1, max_col=1):
        for cell in row:
            if cell.value and norm_label in normalize(str(cell.value)):
                result.append(cell.row)
    return result


# ──────────────────────────────────────────────
# Excelから埋め込み画像を取得 {(row, col): PILImage}
# ──────────────────────────────────────────────
def get_embedded_images(path):
    wb = load_workbook(path)
    ws = wb.active
    images = {}
    for img in ws._images:
        anchor = img.anchor
        if hasattr(anchor, '_from'):
            row = anchor._from.row + 1
            col = anchor._from.col + 1
        else:
            row = anchor.row + 1
            col = anchor.col + 1
        try:
            raw = img.ref
            if hasattr(raw, 'read'):
                raw.seek(0)
            pil_img = PILImage.open(raw).copy()
            if (row, col) not in images:
                images[(row, col)] = pil_img
        except Exception as e:
            print(f"  ⚠ 画像取得失敗 ({row},{col}): {e}")
    return images


# ──────────────────────────────────────────────
# Excelからセル値を取得 {(row, col): value}
# ──────────────────────────────────────────────
def get_cell_values(path):
    wb = load_workbook(path, data_only=True)
    ws = wb.active
    values = {}
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                values[(cell.row, cell.column)] = cell.value
    return values


# ──────────────────────────────────────────────
# Sheets API で特定行の「セル内画像」URLを取得
# （下駄など Excel変換で消える画像に対応）
# ──────────────────────────────────────────────
def get_cell_images_from_sheets_api(service, spreadsheet_id, gid, target_row_index, num_cols=30):
    """
    Sheets API v4 の spreadsheets.get で IMAGE セルの情報を取得。
    target_row_index: 0始まりの行インデックス
    戻り値: {col_index(0始まり): image_url}
    """
    result = {}
    try:
        sheet_data = service.spreadsheets().get(
            spreadsheetId=spreadsheet_id,
            fields='sheets(properties,data(rowData(values(userEnteredValue,effectiveValue,hyperlink))))',
            includeGridData=True,
            ranges=[f"R{target_row_index+1}C1:R{target_row_index+1}C{num_cols}"]
        ).execute()

        for sheet in sheet_data.get('sheets', []):
            if str(sheet['properties']['sheetId']) != str(gid):
                continue
            for row_data in sheet.get('data', [{}])[0].get('rowData', []):
                for ci, cell in enumerate(row_data.get('values', [])):
                    uev = cell.get('userEnteredValue', {})
                    formula = uev.get('formulaValue', '')
                    if formula.upper().startswith('=IMAGE('):
                        url_match = re.search(r'=IMAGE\(["\']([^"\']+)["\']', formula, re.IGNORECASE)
                        if url_match:
                            result[ci] = url_match.group(1)
    except Exception as e:
        print(f"  ⚠ Sheets API 画像取得失敗: {e}")
    return result


def download_image_from_url(url, creds):
    """URLから画像をダウンロードしてPILImageで返す"""
    try:
        headers = {"Authorization": f"Bearer {creds.token}"}
        resp = requests.get(url, headers=headers, timeout=15)
        if resp.status_code == 200:
            return PILImage.open(BytesIO(resp.content)).copy()
    except Exception as e:
        print(f"  ⚠ URL画像ダウンロード失敗: {e}")
    return None


