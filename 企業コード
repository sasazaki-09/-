function searchFiveCompanies() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const inputSheet = ss.getSheets()[0];

  const keyword = '飲食・ファッション・美容・ウェルビーイング系のD2C・ベンチャー・オーナー企業から関西コレクションへの協賛投資価値が高い企業を独自に選定してください。毎回異なる企業を選んでください。';

  inputSheet.getRange('A5').setValue('🔍 5社サーチ中...');
  SpreadsheetApp.flush();

  try {
    // ── 修正①：既存企業名を取得して重複チェックに使用 ──────────────────
    const attackSheet = ss.getSheetByName(ATTACK_SHEET_NAME);
    if (!attackSheet) {
      inputSheet.getRange('A5').setValue('❌ 「' + ATTACK_SHEET_NAME + '」シートが見つかりません');
      return;
    }

    const existingNames = getExistingCompanyNames(attackSheet);
    // ─────────────────────────────────────────────────────────────────────

    const companies = searchFiveCompaniesByGemini(keyword, existingNames);

    if (!companies || companies.length === 0) {
      inputSheet.getRange('A5').setValue('❌ 企業が取得できませんでした');
      return;
    }

    const lastRow = attackSheet.getLastRow();
    let writeRow = lastRow < START_ROW ? START_ROW : lastRow + 1;

    // ── 修正①：重複企業をスキップして追記 ───────────────────────────────
    let addedCount = 0;
    for (let i = 0; i < companies.length; i++) {
      const company = companies[i];
      if (existingNames.indexOf(company.companyName) !== -1) {
        Logger.log('重複スキップ: ' + company.companyName);
        continue;
      }
      attackSheet.getRange(writeRow + addedCount, COL_COMPANY).setValue(company.companyName);

      // URL生死確認 → 死んでいればSerpApiで修正
      let verifiedUrl = company.url;
      if (verifiedUrl && verifiedUrl !== '不明' && verifiedUrl.startsWith('http')) {
        try {
          const checkRes = UrlFetchApp.fetch(verifiedUrl, {
            muteHttpExceptions: true,
            followRedirects: true
          });
          if (checkRes.getResponseCode() !== 200) {
            Logger.log('URL無効→SerpApi修正: ' + verifiedUrl);
            verifiedUrl = fetchUrlBySerpApi(company.companyName);
          }
        } catch (e) {
          Logger.log('URLチェックエラー→SerpApi修正: ' + e.toString());
          verifiedUrl = fetchUrlBySerpApi(company.companyName);
        }
      } else {
        verifiedUrl = fetchUrlBySerpApi(company.companyName);
      }

      attackSheet.getRange(writeRow + addedCount, COL_URL).setValue(verifiedUrl);
      attackSheet.getRange(writeRow + addedCount, COL_GEMTEXT).setValue(company.mailText);
      addedCount++;
    }
    // ─────────────────────────────────────────────────────────────────────

    const skippedCount = companies.length - addedCount;
    const resultMsg = addedCount > 0
      ? 'アタックリストの' + writeRow + '行目から' + addedCount + '社を追記しました。'
        + (skippedCount > 0 ? '\n（重複 ' + skippedCount + '社はスキップ）' : '')
      : '追記できる新規企業がありませんでした。\n（全' + skippedCount + '社が重複）';

    inputSheet.getRange('A5').setValue('✅ 完了！' + resultMsg);
    SpreadsheetApp.getUi().alert('✅ 5社サーチ完了！\n\n' + resultMsg + '\n次に「メールサーチ実行」ボタンを押してください。');

  } catch (e) {
    inputSheet.getRange('A5').setValue('❌ エラー: ' + e.message);
    Logger.log('エラー詳細: ' + e.toString());
    SpreadsheetApp.getUi().alert('エラーが発生しました:\n' + e.message);
  }
}

