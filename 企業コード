// 共通関数：カテゴリ解決
// ========================================================
function resolveTargetSheet(category) {
  if (VALID_CATEGORIES.indexOf(category) !== -1) return category;
  return 'その他';
}

// ========================================================
// 共通関数：次の書き込み行を取得（4行目起点）
// ========================================================
function getNextWriteRow(sheet) {
  const START_ROW_WRITE = 4;
  const CHECK_COLS = 4;
  const lastRow = sheet.getLastRow();
  if (lastRow < START_ROW_WRITE) return START_ROW_WRITE;
  const numRows = lastRow - START_ROW_WRITE + 1;
  const values = sheet.getRange(START_ROW_WRITE, 1, numRows, CHECK_COLS).getValues();
  for (let i = values.length - 1; i >= 0; i--) {
    if (values[i][0] || values[i][2] || values[i][3]) {
      return START_ROW_WRITE + i + 1;
    }
  }
  return START_ROW_WRITE;
}
