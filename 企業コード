function organizeCompanyInfo() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const inputSheet = ss.getSheets()[0];
  const companyName = inputSheet.getRange('A1').getValue().toString().trim();

  if (!companyName) {
    SpreadsheetApp.getUi().alert('A1セルに企業名を入力してください。');
    return;
  }

  inputSheet.getRange('A2').setValue('🔍 リサーチ中...');
  SpreadsheetApp.flush();

  try {
    const result = callGeminiAPI(companyName);
    if (!result) {
      inputSheet.getRange('A2').setValue('❌ APIエラー: 結果を取得できませんでした');
      return;
    }

    const targetSheetName = resolveTargetSheet(result.category);
