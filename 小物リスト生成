PEOPLE_PER_SLIDE = 11  # 1スライドあたりの人数

# ============================================================
# A列ラベルから行番号を自動取得
# ============================================================
def get_label_rows(path):
    wb = load_workbook(path, data_only=True)
    ws = wb.active

    label_rows = {}
    for row in ws.iter_rows(min_col=1, max_col=1):
        for cell in row:
            if cell.value:
                val = str(cell.value).strip()
                if val == 'モデル名':
                    label_rows['name'] = cell.row
                elif val == 'モデル写真':
                    label_rows['face'] = cell.row
                elif val == '下駄':
                    label_rows['shoes'] = cell.row
                elif val == '他小物':
                    label_rows['item'] = cell.row
    return label_rows

# ============================================================
# Excel読み込み関数
# ============================================================
def get_embedded_images(path):
    wb = load_workbook(path)
    ws = wb.active
    images = {}
    for img in ws._images:
        anchor = img.anchor
        if hasattr(anchor, '_from'):
            row = anchor._from.row + 1
            col = anchor._from.col + 1
        else:
            row = anchor.row + 1
            col = anchor.col + 1
        try:
            raw = img.ref
            if hasattr(raw, 'read'):
                raw.seek(0)
            pil_img = PILImage.open(raw).copy()
            if (row, col) not in images:
                images[(row, col)] = pil_img
        except Exception as e:
            print(f"  ⚠ 画像取得失敗 ({row},{col}): {e}")
    return images

def get_cell_values(path):
    wb = load_workbook(path, data_only=True)
    ws = wb.active
    values = {}
    for row in ws.iter_rows():
        for cell in row:
            if cell.value is not None:
                values[(cell.row, cell.column)] = cell.value
    return values

# ============================================================
# パワポ操作関数
# ============================================================
def replace_picture(shape, pil_image):
    buf = BytesIO()
    pil_image.save(buf, format="PNG")
    buf.seek(0)
    blip = shape._element.find('.//{http://schemas.openxmlformats.org/drawingml/2006/main}blip')
    if blip is None:
        return False
    r_embed = '{http://schemas.openxmlformats.org/officeDocument/2006/relationships}embed'
    _, new_rId = shape.part.get_or_add_image_part(buf)
    blip.set(r_embed, new_rId)
    return True

def delete_picture(shape):
    sp = shape._element
    sp.getparent().remove(sp)
    return True

def set_cell_text(cell, text):
    for para in cell.text_frame.paragraphs:
        for run in para.runs:
            run.text = ""
    if cell.text_frame.paragraphs[0].runs:
        cell.text_frame.paragraphs[0].runs[0].text = str(text)
    else:
        cell.text_frame.paragraphs[0].text = str(text)

def clear_table_cell(cell):
    """テーブルセルを空白にする"""
    for para in cell.text_frame.paragraphs:
        for run in para.runs:
            run.text = ""
    if cell.text_frame.paragraphs[0].runs:
        cell.text_frame.paragraphs[0].runs[0].text = ""
    else:
        cell.text_frame.paragraphs[0].text = ""

