import re

# ここにメールで受け取ったURLを貼り付ける
SHEET_URL = "https://docs.google.com/spreadsheets/d/1A5zAAZv9tpknuGtNaDRVvYA6H1kRgRlJmt1oJE6RXz8/edit?pli=1&gid=795366735#gid=795366735"

def extract_ids_from_url(url):
    spreadsheet_id = re.search(r'/spreadsheets/d/([a-zA-Z0-9-_]+)', url)
    gid = re.search(r'gid=(\d+)', url)
    spreadsheet_id = spreadsheet_id.group(1) if spreadsheet_id else None
    gid = gid.group(1) if gid else None
    return spreadsheet_id, gid

SPREADSHEET_ID, GID = extract_ids_from_url(SHEET_URL)
print(f"SPREADSHEET_ID: {SPREADSHEET_ID}")
print(f"GID: {GID}")

# 取得できなかった場合はエラー
if not SPREADSHEET_ID or not GID:
    raise RuntimeError("URLからIDの取得に失敗しました。URLを確認してください。")

